# Phish.net API key — request one at https://phish.net/api/keys (log into your free Phish.net account first)
PHISHNET_API_KEY=

# Truth Social bearer token for the bot account.
# Get it: log into truthsocial.com as the bot account -> DevTools -> Network ->
# click any /api/ request -> copy the Authorization header value after "Bearer ".
TRUTH_BEARER_TOKEN=

# Comma-separated platforms to post to. "x" arrives in phase 2.
PLATFORMS=truthsocial

# SQLite state file location
STATE_DB=botstate.db
